#!/usr/bin/env bash
set -euo pipefail

REMOTE_HOST="terry@10.0.0.99"
REMOTE_DIR="~/PixelDoodle"
TMUX_SESSION="main"

ssh "${REMOTE_HOST}" "cd ${REMOTE_DIR} && git pull --ff-only"
ssh "${REMOTE_HOST}" "tmux has-session -t ${TMUX_SESSION} && tmux send-keys -t ${TMUX_SESSION} C-c && tmux send-keys -t ${TMUX_SESSION} 'cd ${REMOTE_DIR} && python3 main.py' C-m"
